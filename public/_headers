# Content-hashed assets — cache indefinitely (hash changes on new build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker — must revalidate so clients detect updates
/sw.js
  Cache-Control: no-cache

# HTML and other non-hashed files — always revalidate, plus security headers
/*
  Cache-Control: no-cache
  Content-Security-Policy: frame-ancestors 'none'
