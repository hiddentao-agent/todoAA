# Content-hashed assets — cache indefinitely (hash changes on new build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker — must revalidate so clients detect updates
/sw.js
  Cache-Control: no-cache

# HTML entry points — always revalidate (never cache)
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Security headers (all responses) — no Cache-Control here to avoid overriding asset rules
/*
  Content-Security-Policy: frame-ancestors 'none'
